#!/bin/sh
# ============================================================================
# commit-msg hook — git-native AI-attribution guard (defence-in-depth layer 2).
#
# Layer 1 (Claude PreToolUse Bash hook → git-guard.sh) only sees commits going
# through Claude's Bash tool. This hook catches every other commit path:
#   - VS Code Source Control UI
#   - GitKraken / SourceTree / Magit
#   - External CI bots running `git commit` directly
#   - Manual `git rebase -i` reword sessions in a host terminal
#   - Any developer workflow not involving Claude at all
#
# Activated by `step_git_hooks_path` in postCreate.sh which sets
# `core.hooksPath=.githooks` on the consumer repo. POSIX `sh` for portability.
#
# Bypass: `git commit --no-verify` skips it (intentional escape hatch for
# emergencies). Server-side enforcement (pre-receive / branch protection)
# is the next defence layer — out of scope for this hook.
# ============================================================================
set -eu
MSG_FILE="$1"

if grep -i -E '(co-authored-by:[[:space:]]*(claude|anthropic|ai|gpt|copilot|gemini|llm)|generated[[:space:]]+(by|with)[[:space:]]+(claude|ai|gpt))' "$MSG_FILE" >/dev/null 2>&1 \
   || grep -F '🤖' "$MSG_FILE" >/dev/null 2>&1; then
    printf '\n❌ commit-msg hook: AI attribution detected.\n\n'
    printf 'Project policy (CLAUDE.md): NO AI IN COMMITS.\n'
    printf 'Forbidden patterns:\n'
    printf '  - Co-Authored-By: Claude/Anthropic/AI/GPT/Copilot/Gemini/LLM\n'
    printf '  - Generated by/with Claude/AI/GPT\n'
    printf '  - Robot emoji 🤖\n\n'
    printf 'Offending lines:\n'
    grep -i -n -E '(co-authored-by:[[:space:]]*(claude|anthropic|ai|gpt|copilot|gemini|llm)|generated[[:space:]]+(by|with)[[:space:]]+(claude|ai|gpt))' "$MSG_FILE" | sed 's/^/    /' || true
    grep -F -n '🤖' "$MSG_FILE" | sed 's/^/    /' || true
    printf '\nStrip the AI-attribution lines and retry.\n\n'
    exit 1
fi

exit 0
